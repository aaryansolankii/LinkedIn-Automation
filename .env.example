# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_sending_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
OWNER_EMAIL=your_receiving_email@gmail.com

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_long_linkedin_access_token_here
LINKEDIN_AUTHOR_URN=urn:li:organization:your_company_id

# Scheduler
SCHEDULER_TIME=23:11
POSTING_TIME=10:00

# LinkedIn App Config (Used by get_token.py helper)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
